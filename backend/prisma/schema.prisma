generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  password     String   @default("123456")
  fullName     String?
  phone        String?  // BỔ SUNG: Số điện thoại
  address      String?  @db.Text // BỔ SUNG: Địa chỉ mặc định
  role         String   @default("USER")
  orders       Order[]
  reviews      Review[]
  interactions UserInteraction[] // BỔ SUNG: Quan hệ với bảng tương tác (Dùng cho AI)
  
  // BẠN THÊM DÒNG NÀY VÀO ĐÂY NHÉ:
  chatMessages ChatMessage[] 

  createdAt    DateTime @default(now())
}

model Product {
  id           Int         @id @default(autoincrement())
  name         String
  description  String?     @db.Text
  price        Float
  costPrice    Float
  stock        Int         @default(100)
  image        String?     @db.Text
  category     String      // (Nâng cao: Có thể tách bảng Category riêng nếu muốn)
  orderItems   OrderItem[]
  reviews      Review[]
  interactions UserInteraction[] // BỔ SUNG: Quan hệ với bảng tương tác
  // relation to cart items so CartItem.product has an opposite field
  cartItems     CartItem[]
  createdAt    DateTime    @default(now())
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int
  user            User        @relation(fields: [userId], references: [id])
  totalAmount     Float
  status          String      @default("COMPLETED")
  
  // --- BỔ SUNG THÔNG TIN GIAO HÀNG ---
  shippingAddress String?     @db.Text  // Thêm dấu ? để không lỗi dữ liệu cũ
  phoneNumber     String?               // Thêm dấu ? 
  paymentMethod   String      @default("COD")
  notes           String?     @db.Text 
  // -----------------------------------

  items           OrderItem[]
  createdAt       DateTime    @default(now())
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}
model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sender    String   // Lưu giá trị: "USER" hoặc "AI"
  message   String   @db.Text
  createdAt DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  rating    Int      @default(5)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
}

// ==========================================
// CÁC BẢNG MỚI ĐỀ XUẤT THÊM
// ==========================================

// 1. Bảng thu thập hành vi người dùng (Cực kỳ tốt cho AI Recommendation)
model UserInteraction {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  action    String   // Các giá trị: "VIEW" (Xem), "ADD_TO_CART" (Thêm giỏ hàng)
  createdAt DateTime @default(now())
}

// 2. Bảng Giỏ hàng (Chỉ cần nếu bạn không muốn dùng localStorage)
model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int        @unique // Mỗi user có 1 giỏ hàng duy nhất đang active
  items     CartItem[]
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        Int     @id @default(autoincrement())
  cart      Cart    @relation(fields: [cartId], references: [id])
  cartId    Int
  product   Product @relation(fields: [productId], references: [id])  // <-- name matters
  productId Int
  quantity  Int
}